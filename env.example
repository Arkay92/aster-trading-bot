ASTER_RPC_URL=https://fapi.asterdex.com
ASTER_WS_URL=wss://fstream.asterdex.com/ws
ASTER_API_KEY=
ASTER_API_SECRET=
ASTER_PRIVATE_KEY=
ASTER_USER_ADDRESS=
ASTER_SIGNER_ADDRESS=
ASTER_SIGNER_PRIVATE_KEY=
ASTER_SOURCE_ADDR=
ASTER_CHAIN_ID=56
ASTER_NETWORK=56
ASTER_SOURCE_CODE=broker
ASTER_AGENT_CODE=
PAIR_SYMBOL=ASTERUSDT-PERP
ENABLE_DYNAMIC_PAIR_RANKING=false

# Strategy Type: "watermellon", "peach-hybrid", or "swing"
STRATEGY_TYPE=peach-hybrid
RUN_ALL_STRATEGIES=false

# Virtual Timeframe (milliseconds)
VIRTUAL_TIMEFRAME_MS=30000

# Risk Management
MAX_POSITION_USDT=10000
# MAX_LEVERAGE: (10x, 20x, 50x are available for normal version) premium support 1000x
MAX_LEVERAGE=5
MAX_FLIPS_PER_HOUR=12
QUIET_SIGNAL_LOGS=true
STRATEGY_OWNERSHIP_TIMEOUT_BARS=6
STOP_LOSS_PCT=0
TAKE_PROFIT_PCT=0
USE_STOP_LOSS=false
EMERGENCY_STOP_LOSS_PCT=2.0
MAX_POSITIONS=1
MAX_POSITIONS_PER_STRATEGY=1
MAX_POSITIONS_WATERMELLON=
MAX_POSITIONS_PEACH_HYBRID=
MAX_POSITIONS_SWING=
MAX_POSITIONS_EMA_CROSS=
MAX_POSITIONS_RSI_REVERSION=

# Watermellon Strategy Parameters (if STRATEGY_TYPE=watermellon)
EMA_FAST=8
EMA_MID=21
EMA_SLOW=48
RSI_LENGTH=14
RSI_MIN_LONG=45
RSI_MAX_SHORT=55

# Peach Hybrid V1 System (Trend/Bias)
PEACH_V1_EMA_FAST=8
PEACH_V1_EMA_MID=21
PEACH_V1_EMA_SLOW=48
PEACH_V1_EMA_MICRO_FAST=5
PEACH_V1_EMA_MICRO_SLOW=13
PEACH_V1_RSI_LENGTH=14
PEACH_V1_RSI_MIN_LONG=45
PEACH_V1_RSI_MAX_SHORT=55
PEACH_V1_MIN_BARS_BETWEEN=1
PEACH_V1_MIN_MOVE_PCT=0.05

# Peach Hybrid V2 System (Momentum Surge)
PEACH_V2_EMA_FAST=3
PEACH_V2_EMA_MID=8
PEACH_V2_EMA_SLOW=13
PEACH_V2_RSI_MOMENTUM_THRESHOLD=2.0
PEACH_V2_VOLUME_LOOKBACK=4
PEACH_V2_VOLUME_MULTIPLIER=1.2
PEACH_V2_EXIT_VOLUME_MULTIPLIER=1.0

# Swing Strategy (buy dips, sell highs)
SWING_EMA_TREND_LEN=50
SWING_RSI_LENGTH=14
SWING_RSI_DIP_THRESHOLD=38
SWING_RSI_HIGH_THRESHOLD=62
SWING_LOOKBACK_BARS=20
SWING_DIP_PCT_FROM_HIGH=1.2
SWING_BOUNCE_CONFIRM_PCT=0.25

# EMA Cross Strategy
EMA_CROSS_FAST_LEN=9
EMA_CROSS_SLOW_LEN=26
EMA_CROSS_RSI_LENGTH=14
EMA_CROSS_RSI_MIN_LONG=45
EMA_CROSS_RSI_MAX_SHORT=55

# RSI Reversion Strategy
RSI_REV_RSI_LENGTH=14
RSI_REV_OVERSOLD=32
RSI_REV_OVERBOUGHT=68
RSI_REV_EMA_TREND_LEN=50

# Paper Trading Mode
PAPER_TRADING=true
PAPER_STARTING_BALANCE=10000

MODE=dry-run
SET_LEVERAGE_ON_ORDER=false

